# development / test / production
NODE_ENV=development
PORT=3010
DATABASE_URL=postgresql://zhaoxiaogang:xiaochuang@localhost:5432/xiaochuang?schema=public
REDIS_URL=redis://127.0.0.1:6379
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
SESSION_COOKIE_NAME=xiaochuang_session
SESSION_DURATION_DAYS=7

# local / s3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=../data/static
# local 开发可用 backend /static；生产环境启动时要求 STORAGE_DRIVER=s3 且使用远程公开地址
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:3010/static

# S3-compatible storage settings（当 STORAGE_DRIVER=s3 时必填）
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# MinIO 本地开发示例（推荐作为 V2.0 对象存储主链路验证口径）
# 先执行：npm run runtime:up（同时启动 PostgreSQL / Redis / MinIO）
# 或仅执行：bash tools/start-minio-dev.sh（只启动 MinIO）
# STORAGE_DRIVER=s3
# STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9000/xiaochuang-media
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=xiaochuang-media
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin123

# ===== 火山方舟（Volcengine Ark）模型 =====
# 文档：https://www.volcengine.com/docs/82379/?lang=zh
# 在本地 .env 中填入真实值后，运行 `npm run volc:setup`（apps/backend）
# 即可把以下模型写入当前用户的 AI 服务配置（默认 AI_SETUP_USER_ID=1）。请勿提交真实密钥。
AI_SETUP_USER_ID=1
VOLC_ARK_API_KEY=
VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com
# 文本模型（接入点 ID，例如 ep-xxxxxxxx）
VOLC_TEXT_MODEL_PRO=
VOLC_TEXT_MODEL_DEEPSEEK=
VOLC_TEXT_MODEL_MINI=
# 视频模型（接入点 ID）
VOLC_VIDEO_MODEL_SEEDANCE=

# ===== 其他 P0 厂商（本地测试，勿提交密钥）=====
# 运行 npm run ai:setup-local 写入当前用户配置（见 AI_SETUP_USER_ID）
MOONSHOT_API_KEY=
MOONSHOT_TEXT_MODEL=moonshot-v1-8k
DEEPSEEK_API_KEY=
DEEPSEEK_TEXT_MODEL=deepseek-chat
MINIMAX_TEXT_MODEL=abab6.5s-chat
ALI_API_KEY=
ALI_TEXT_MODEL=qwen-plus
# 快手可灵（JWT：Access Key + Secret Key，无 Key 时可只对接不测试）
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_VIDEO_MODEL=kling-v2-6

# ===== Mock AI（仅专项调试，默认不要开启）=====
# mock 代码保留用于专项联调，但默认链路已切换到真实服务。
# 如需把 mock 配置重新写入数据库，必须显式授权：
#   ALLOW_MOCK_AI_SETUP=1 npm run mock:ai:setup --workspace apps/backend
# 或：
#   npm run mock:ai:setup --workspace apps/backend -- --allow-mock-setup
ALLOW_MOCK_AI_SETUP=0
