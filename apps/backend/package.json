{
  "name": "@xiaochuang/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "openapi:export": "npm run build && node dist/src/openapi-export.js",
    "media:audit": "node --import tsx src/audit-media-storage.ts",
    "media:audit:strict": "node --import tsx src/audit-media-storage.ts --fail-on-legacy",
    "media:audit:object-storage": "node --import tsx src/audit-media-storage.ts --require-object-storage",
    "storage:smoke": "npm run build && node dist/src/smoke-storage.js",
    "storage:smoke:object-storage": "npm run build && node dist/src/smoke-storage.js --require-object-storage",
    "upload:smoke": "npm run build && node dist/src/smoke-upload.js",
    "upload:smoke:object-storage": "npm run build && node dist/src/smoke-upload.js --require-object-storage",
    "queue:smoke": "npm run build && node dist/src/smoke-queue-media.js",
    "queue:smoke:object-storage": "npm run build && node dist/src/smoke-queue-media.js --require-object-storage",
    "queue:smoke:ai": "npm run build && node dist/src/smoke-queue-ai.js",
    "queue:smoke:ai:object-storage": "npm run build && node dist/src/smoke-queue-ai.js --require-object-storage",
    "mock:ai": "node --import tsx src/mock-ai-server.ts",
    "mock:ai:setup": "node --import tsx src/setup-mock-ai.ts",
    "ai:cleanup-mock": "node --import tsx src/cleanup-mock-ai.ts",
    "volc:setup": "node --import tsx src/setup-volcengine-ai.ts",
    "ai:setup-local": "node --import tsx src/setup-volcengine-ai.ts && node --import tsx src/setup-local-ai-providers.ts",
    "media:backfill": "node --import tsx src/backfill-media-public-urls.ts",
    "media:backfill:dry-run": "node --import tsx src/backfill-media-public-urls.ts --dry-run",
    "tasks:recover": "node --import tsx src/worker.ts --once",
    "tasks:recover:dry-run": "node --import tsx src/worker.ts --once --dry-run",
    "tasks:worker": "node --import tsx src/worker-main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:init": "npm run db:push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@xiaochuang/contracts": "*",
    "@fastify/cookie": "^11.0.2",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/testing": "^11.1.8",
    "@nestjs/platform-fastify": "^11.1.8",
    "@nestjs/swagger": "^11.2.0",
    "bullmq": "^5.77.6",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.1",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.11.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6",
    "typescript": "6.0.2",
    "vitest": "^2.1.9"
  }
}
