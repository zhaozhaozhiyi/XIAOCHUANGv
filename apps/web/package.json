{
  "name": "@xiaochuang/web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node scripts/run-next.mjs .next-dev dev -p 3001 -H 127.0.0.1",
    "dev:turbo": "node scripts/run-next.mjs .next-dev dev --turbopack -p 3001 -H 127.0.0.1",
    "dev:warm": "node scripts/dev-with-warmup.mjs",
    "dev:clean": "node scripts/run-next.mjs --clean .next-dev dev -p 3001 -H 127.0.0.1",
    "dev:warmup": "node scripts/warmup-dev-routes.mjs",
    "build": "node scripts/run-next.mjs .next-prod build",
    "start": "node scripts/run-next.mjs .next-prod start -p 3001 -H 0.0.0.0",
    "tasks:recover": "npm --prefix ../backend run tasks:recover",
    "tasks:recover:dry-run": "npm --prefix ../backend run tasks:recover:dry-run",
    "tasks:worker": "npm --prefix ../backend run tasks:worker",
    "lint": "eslint .",
    "validate:p2": "python3 scripts/validate_p2_links.py",
    "check:p2": "npm --prefix ../.. run verify:v2-boundaries && npm run validate:p2",
    "test:e2e": "playwright test",
    "test:e2e:workbench": "playwright test e2e/prd-workbench.spec.ts --project=chromium --workers=1",
    "test:e2e:workbench:real": "E2E_REAL_MEDIA=1 playwright test e2e/prd-workbench-real-media.spec.ts --project=chromium --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:canvas": "playwright test --config=playwright.canvas.config.ts",
    "test:e2e:canvas:ui": "playwright test --config=playwright.canvas.config.ts --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@mastra/core": "^1.24.1",
    "@phosphor-icons/react": "^2.1.10",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4.2.2",
    "@xiaochuang/canvas-shared": "*",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "immer": "^11.1.4",
    "lucide-react": "^1.8.0",
    "next": "^15.5.15",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.52.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@storybook/testing-library": "^0.2.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "prettier": "^3.8.3",
    "storybook": "^10.4.1",
    "typescript": "6.0.2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
