# PostgreSQL 数据库（生产环境）
DATABASE_URL=postgresql://user:password@localhost:5432/xiaochuang
BACKEND_BASE_URL=http://127.0.0.1:3010
# 浏览器可直连的 backend 公网地址；若未单独设置 NEXT_PUBLIC_MEDIA_BASE_URL，可用它拼接 /static
NEXT_PUBLIC_BACKEND_BASE_URL=http://127.0.0.1:3010
NEXT_PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:3010/static

# 画布 v0.2.0 前端开发用：启用后由 MSW (Mock Service Worker) 拦截 /api/canvases/*、
# 启用后由 MSW 拦截 /api/canvases/* 等画布相关请求，
# 前端可在不依赖后端的情况下完整跑通画布交互。
# 后端 canvas 模块上线后置 disabled 即切回真实接口。
NEXT_PUBLIC_API_MOCKING=disabled

# 对象存储 / MinIO 验证时，建议显式设置为 bucket 公开地址，例如：
# NEXT_PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:9000/xiaochuang-media

# 本地开发登录（development 默认开启；生产环境无效）
# DEV_AUTH_BYPASS=0
DEV_AUTH_PHONE=13800138000
DEV_AUTH_CODE=123456

# 短信验证码服务
# 开发环境可留空，默认仅控制台输出验证码；生产环境请显式设置 SMS_PROVIDER
# SMS_PROVIDER=aliyun
# SMS_SIGN_NAME=你的签名
# SMS_TEMPLATE_CODE=SMS_000000000
# SMS_TEMPLATE_CODE_REGISTER=SMS_000000001
# SMS_TEMPLATE_CODE_LOGIN=SMS_000000002
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_SMS_REGION_ID=cn-hangzhou
# ALIYUN_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com/

# 以下 Admin 配置仅保留给历史兼容链路，默认登录注册已不再依赖 Admin OAuth
ADMIN_BASE_URL=https://admin.lemonclaw.cc
ADMIN_OAUTH_CLIENT_ID=xiaochuang-web
ADMIN_OAUTH_CLIENT_SECRET=oauth_7e617a72b6b3d7d51f63b75e412af012e6640f726c69aafc
ADMIN_OAUTH_SCOPE=models:read quota:read

# VolcEngine streaming TTS
VOLC_APP_ID=
VOLC_ACCESS_KEY=
VOLC_RESOURCE_ID=volc.service_type.10029
VOLC_ENCODING=mp3
VOLC_BIT_RATE=128000
VOLC_VOICE=zh_male_guozhoudege_moon_bigtts
# Optional: comma-separated voices in the format voice_id|display_name|language
# VOLC_VOICES=zh_male_guozhoudege_moon_bigtts|火山国州的歌|中文,BV002_streaming|BV002|中文
VOLC_SAMPLE_RATE=24000
VOLC_ENDPOINT=wss://openspeech.bytedance.com/api/v3/tts/bidirection
