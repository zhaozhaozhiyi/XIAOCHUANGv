{
  "name": "xiaochuangpro",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:web:turbo": "npm run dev:turbo --workspace apps/web",
    "dev:web:warm": "npm run dev:warm --workspace apps/web",
    "dev:admin": "npm run dev --workspace apps/admin",
    "dev:backend": "npm run dev --workspace apps/backend",
    "dev:app": "npm run dev:web",
    "dev:all": "concurrently -k -n web,admin,backend \"npm run dev:web\" \"npm run dev:admin\" \"npm run dev:backend\"",
    "build:web": "npm run build --workspace apps/web",
    "build:admin": "npm run build --workspace apps/admin",
    "build:backend": "npm run build --workspace apps/backend",
    "test:e2e:workbench": "npm run test:e2e:workbench --workspace apps/web",
    "test:e2e:workbench:real": "npm run test:e2e:workbench:real --workspace apps/web",
    "generate:contracts": "npm run --workspace apps/backend openapi:export -- --output ../../packages/contracts/openapi.json && npm run generate --workspace packages/contracts",
    "build:contracts": "npm run generate:contracts && npm run build --workspace packages/contracts",
    "build:ui": "npm run build --workspace packages/ui",
    "verify:v2-boundaries": "node tools/check-v2-boundaries.mjs",
    "runtime:up": "node tools/docker-compose-runtime.mjs up -d",
    "runtime:down": "node tools/docker-compose-runtime.mjs down",
    "audit:v2-completion": "node tools/audit-v2-completion.mjs",
    "audit:v2-completion:local": "node tools/audit-v2-completion.mjs --local",
    "audit:v2-completion:quick": "node tools/audit-v2-completion.mjs --quick",
    "check:v2-runtime": "node tools/check-v2-runtime.mjs",
    "audit:media": "npm run media:audit --workspace apps/backend",
    "audit:media:strict": "npm run media:audit:strict --workspace apps/backend",
    "audit:object-storage": "npm run media:audit:object-storage --workspace apps/backend",
    "storage:smoke": "npm run storage:smoke --workspace apps/backend",
    "storage:smoke:object-storage": "npm run storage:smoke:object-storage --workspace apps/backend",
    "upload:smoke": "npm run upload:smoke --workspace apps/backend",
    "upload:smoke:object-storage": "npm run upload:smoke:object-storage --workspace apps/backend",
    "queue:smoke": "npm run queue:smoke --workspace apps/backend",
    "queue:smoke:object-storage": "npm run queue:smoke:object-storage --workspace apps/backend",
    "queue:smoke:ai": "npm run queue:smoke:ai --workspace apps/backend",
    "queue:smoke:ai:object-storage": "npm run queue:smoke:ai:object-storage --workspace apps/backend",
    "mock:ai": "npm run mock:ai --workspace apps/backend",
    "mock:ai:setup": "npm run mock:ai:setup --workspace apps/backend",
    "ai:cleanup-mock": "npm run ai:cleanup-mock --workspace apps/backend",
    "volc:setup": "npm run volc:setup --workspace apps/backend",
    "db:init": "npm run db:init --workspace apps/backend",
    "db:generate": "npm run db:generate --workspace apps/backend",
    "db:migrate": "npm run db:migrate --workspace apps/backend",
    "db:push": "npm run db:push --workspace apps/backend",
    "audit:v2-runtime": "node tools/run-v2-runtime-gates.mjs",
    "verify:novel-p1": "node tools/verify-novel-p1.mjs",
    "verify:ai-runtime": "node tools/verify-ai-runtime.mjs",
    "verify:skill-driven": "node tools/verify-skill-driven.mjs",
    "verify:e6-handoff": "node tools/verify-e6-handoff.mjs",
    "verify:e6-qa-record": "node tools/verify-e6-qa-record.mjs",
    "qa:e6-pending": "node tools/verify-e6-qa-record.mjs --markdown",
    "qa:e6-pending:write": "node tools/verify-e6-qa-record.mjs --output=docs/v2.0/e6-qa-runtime-pending-2026-06-06.md",
    "verify:e6-qa-pending": "node tools/verify-e6-qa-record.mjs --check-archive",
    "verify:e6-release-ready": "node tools/verify-e6-release-ready.mjs",
    "verify:task-backlog": "node tools/verify-task-backlog.mjs --check-archive",
    "tasks:open": "node tools/verify-task-backlog.mjs --markdown",
    "tasks:open:write": "node tools/verify-task-backlog.mjs --output=docs/v2.0/open-task-backlog-2026-06-06.md",
    "verify:admin-contracts": "node tools/verify-admin-contracts.mjs",
    "verify:task-recovery": "node tools/verify-task-recovery.mjs",
    "verify:agent-sse": "node tools/verify-agent-sse.mjs",
    "verify:admin-regression": "node tools/verify-admin-regression.mjs",
    "verify:context-resolver": "node tools/verify-context-resolver.mjs",
    "verify:drama-relations": "node tools/verify-drama-relations.mjs",
    "verify:web-api-client": "node tools/verify-web-api-client.mjs",
    "verify:task-ops": "node tools/verify-task-ops.mjs",
    "verify:queue-pipeline": "node tools/verify-queue-pipeline.mjs",
    "verify:object-storage": "node tools/verify-object-storage.mjs",
    "runtime:up:local": "node tools/local-runtime-up.mjs",
    "runtime:down:local": "node tools/local-runtime-down.mjs",
    "check:v2-runtime:local": "node tools/check-v2-runtime.mjs --wait",
    "audit:v2-runtime:local": "node tools/run-v2-runtime-gates.mjs --local-runtime"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@electric-sql/pglite-socket": "^0.2.1",
    "concurrently": "^9.2.1",
    "redis-memory-server": "^0.16.1"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
